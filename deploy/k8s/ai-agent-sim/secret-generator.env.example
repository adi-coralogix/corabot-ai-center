# Copy to secret-generator.env (gitignored) before kubectl apply -k deploy/k8s/ai-agent-sim/
#
# Pairing: TEAM_* RUM + OTLP + optional Guardrail keys MUST match collector egress region in otel-collector.yaml:
#   team A → ingress.us2 (`otlp/cx_a`).
#   team B → ingress.eu1 (`otlp/cx_b`).
#
# coralogix-otel-key-* — Coralogix **Send-Your-Data / Private Key** scoped for OTLP (traces, logs, metrics, profiles).

gemini-api-key=REPLACE_ME

coralogix-otel-key-team-a=REPLACE_ME
coralogix-otel-key-team-b=REPLACE_ME

rum-public-key-team-a=REPLACE_ME
rum-public-key-team-b=REPLACE_ME

# Optional Guardrails — team A Deployment uses US2 REST by default (`coralogix-guardrails-key`).
# Team B uses EU1 (`CX_GUARDRAILS_ENDPOINT`) and should set a separate key aligned with EU1 Coralogix.
# coralogix-guardrails-key=REPLACE_ME
# coralogix-guardrails-key-team-b=REPLACE_ME
