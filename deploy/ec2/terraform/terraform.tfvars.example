# Copy to terraform.tfvars (gitignored) and fill in real values,
# OR pass each as -var="key=value" on the command line.

region        = "us-west-2"
key_pair_name = "my-ec2-key"
domain        = "corabot.coralogix.com"
instance_type = "t3.small"

# Restrict SSH to your IP: "203.0.113.1/32"
# Leave as "0.0.0.0/0" only for testing — lock it down in production.
ssh_cidr = "0.0.0.0/0"

# ── App secrets ───────────────────────────────────────────────────────────────
openai_api_key           = "sk-proj-..."
coralogix_private_key    = "cxtp_..."
coralogix_guardrails_key = "cxtp_..."
vite_coralogix_rum_key   = "cxtp_..."
public_coralogix_domain  = "US2"

cx_guardrails_endpoint = "https://api.us2.coralogix.com/api/v1/guardrails/guard"
guardrails_enabled     = "enable"

# ── Google OAuth2 (console.cloud.google.com → Credentials → OAuth 2.0 Client ID)
# Authorized redirect URI: https://<domain>/oauth2/callback
google_client_id     = "1234567890-abc.apps.googleusercontent.com"
google_client_secret = "GOCSPX-..."
