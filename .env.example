# OpenTelemetry: app → local collector (npm run start uses instrumentation.cjs the same way)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true

# Collector → Coralogix (see otel-collector-config.yaml)
CORALOGIX_PRIVATE_KEY=cxtp_hyz83MM60I5X9ueH92nrlKzx4RrQBD

# Coralogix RUM (browser real user monitoring) - region US2
# VITE_ prefix exposes to client; same value can be used
VITE_CORALOGIX_RUM_KEY=cxtp_AJUlO9UrZx6LjEM1A9Xc71uQB2rUKB

# Google Gemini 2.5 Flash Lite API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Python chat API URL (frontend browser calls this; leave unset in production —
# hooks.server.ts will proxy /api/* to CHAT_API_ORIGIN instead)
# VITE_CHAT_API_URL=http://localhost:8000

# ── Production / EC2 docker-compose ──────────────────────────────────────────
# Domain the app is served on (used by Caddy TLS + oauth2-proxy redirect URL)
DOMAIN=corabot.coralogix.com

# Google OAuth2 (from Google Cloud Console → APIs & Services → Credentials)
# Redirect URI to register: https://${DOMAIN}/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=your-google-client-secret
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
OAUTH2_PROXY_COOKIE_SECRET=your-32-char-random-secret
